{
  "name": "timekeeper",
  "type": "module",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "author": "Bradly Carpenter",
  "scripts": {
    "dev": "doppler run -c=dev -p=timekeeper -- pnpm run -r --parallel --aggregate-output dev",
    "dev:web": "doppler run -c=dev -p=timekeeper -- pnpm run --filter web dev",
    "dev:api": "doppler run -c=dev -p=timekeeper -- pnpm run --filter api dev",
    "db:studio": "pnpm --filter api db:studio",
    "db:generate": "pnpm --filter api db:generate",
    "db:migrate:local": "pnpm --filter api db:migrate:local",
    "format": "prettier --write apps/ packages/",
    "request": "doppler run -c=dev -p=timekeeper -- bash scripts/requests.sh"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.6.0",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "prettier": "^3.8.4"
  }
}
